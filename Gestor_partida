package reto;
import java.util.Scanner;
import java.util.ArrayList;
public class Gestor_partida {

	   private Partida partida;
	   private Scanner sc = new Scanner(System.in);

	   public void nuevaPartida() {

	       System.out.println("Nombre jugador 1:");
	       String j1 = sc.nextLine();

	       System.out.println("Nombre jugador 2:");
	       String j2 = sc.nextLine();

	       pinguino p1 = new Pinguino(j1, "Azul");
	       pinguino p2 = new Pinguino(j2, "Rojo");

	       ArrayList <Jugador> jugadores = new ArrayList<>();
	       jugadores.add(p1);
	       jugadores.add(p2);

	       tablero tablero = new tablero(50);

	       partida = new partida(tablero, jugadores);
	   }
  public void jugar() {

	       while (!partida.isFinalizada()) {

	           jugador actual = partida.getJugadorActual();

	           System.out.println("\nTurno de: " + actual.getNombre());

	           int tirada = actual.tirarDado();
	           System.out.println("Ha sacado: " + tirada);

	           actual.mover(tirada);

	           partida.getTablero().activarCasilla(actual);

	           partida.siguienteTurno();

	           if (actual.getPosicion() >= partida.getTablero().getSize()) {
	               partida.setGanador(actual);
	               partida.setFinalizada(true);
	           }
	       }

	       System.out.println("Ganador: " + partida.getGanador().getNombre());
	   }

}

	
