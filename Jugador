package reto;
  public abstract class jugador {
    protected String nombre;
    protected String color;
    protected int posicion;
    protected inventario inventario;
    protected boolean pierdeTurno;

    public jugador(String nombre, String color) {
        this.nombre = nombre;
        this.color = color;
        this.posicion = 0;
        this.inventario = new inventario();
        this.pierdeTurno = false;
    }

    public void mover(int pasos) {
        posicion += pasos;
        if (posicion < 0) posicion = 0;
    }

    public int tirarDado() {
        return inventario.tirarDado();
    }

    public String getNombre()       { return nombre; }
    public String getColor()        { return color; }
    public int    getPosicion()     { return posicion; }
    public void   setPosicion(int p){ posicion = p; }
    public inventario getInventario(){ return inventario; }

    public boolean isPierdeTurno()       { return pierdeTurno; }
    public void    setPierdeTurno(boolean b){ pierdeTurno = b; }
}

