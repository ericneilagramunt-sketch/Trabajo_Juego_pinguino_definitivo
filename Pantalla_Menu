package reto;

import javax.swing.*;
import java.awt.*;
import java.util.ArrayList;
public class PantallaMenu {

    private gestorpartida gestorPartidas;
    private JFrame        frame;

    public PantallaMenu() {
        this.gestorPartidas = new gestorpartida();
    }



    public void menu() {
        frame = new JFrame("El Juego del pingu");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(440, 360);
        frame.setLocationRelativeTo(null);
        frame.setLayout(new BorderLayout(10, 10));
        frame.getContentPane().setBackground(new Color(20, 80, 130));

        JLabel titulo = new JLabel("El juego del pingu", SwingConstants.CENTER);
        titulo.setFont(new Font("Arial", Font.BOLD, 22));
        titulo.setForeground(Color.WHITE);
        titulo.setBorder(BorderFactory.createEmptyBorder(30, 0, 10, 0));
        frame.add(titulo, BorderLayout.NORTH);

        JLabel subtitulo = new JLabel("El juego de mesa del frio!", SwingConstants.CENTER);
        subtitulo.setFont(new Font("Arial", Font.ITALIC, 13));
        subtitulo.setForeground(new Color(200, 230, 255));

       
        JPanel panelBotones = new JPanel(new GridLayout(4, 1, 0, 12));
        panelBotones.setOpaque(false);
        panelBotones.setBorder(BorderFactory.createEmptyBorder(10, 70, 30, 70));

        JButton btnNueva  = crearBoton("Nueva Partida");
        JButton btnCargar = crearBoton("Cargar Partida");
        JButton btnSalir  = crearBoton("Salir");

        btnNueva.addActionListener(e  -> botonNuevaPartida());
        btnCargar.addActionListener(e -> pedirIdYCargar());
        btnSalir.addActionListener(e  -> botonSalir());

        panelBotones.add(subtitulo);
        panelBotones.add(btnNueva);
        panelBotones.add(btnCargar);
        panelBotones.add(btnSalir);

        frame.add(panelBotones, BorderLayout.CENTER);
        frame.setVisible(true);
    }

public void botonNuevaPartida() {
        // Número de jugadores
        String[] optsNum = {"2", "3", "4"};
        String selNum = (String) JOptionPane.showInputDialog(frame,
                "Cuantos jugadores humanos?", "Nueva Partida",
                JOptionPane.QUESTION_MESSAGE, null, optsNum, optsNum[0]);
        if (selNum == null) return;
        int numJugadores = Integer.parseInt(selNum);

        // Nombres
        ArrayList<String> nombres = new ArrayList<>();
        for (int i = 1; i <= numJugadores; i++) {
            String nombre = JOptionPane.showInputDialog(frame, "Nombre del jugador " + i + ":");
            if (nombre == null || nombre.trim().isEmpty()) nombre = "Jugador" + i;
            nombres.add(nombre.trim());
        }

        // Foca CPU
        int r = JOptionPane.showConfirmDialog(frame,
                "Anadir Foca CPU como rival?", "CPU",
                JOptionPane.YES_NO_OPTION);
        boolean conFoca = (r == JOptionPane.YES_OPTION);

        gestorPartidas.nuevaPartida(nombres, conFoca);
        frame.dispose();
        new PantallaJuego(gestorPartidas).iniciarPartida();
    }

    public void botonCargarPartida(int id) {
        gestorPartidas.cargarPartida(id);
        if (gestorPartidas.getPartida() != null) {
            frame.dispose();
            new PantallaJuego(gestorPartidas).iniciarPartida();
        } else {
            JOptionPane.showMessageDialog(frame,
                    "No se encontro la partida con id=" + id + ".",
                    "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void pedirIdYCargar() {
        String input = JOptionPane.showInputDialog(frame, "ID de la partida a cargar:");
        if (input == null || input.trim().isEmpty()) return;
        try {
            botonCargarPartida(Integer.parseInt(input.trim()));
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(frame, "ID invalido.", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    public void botonSalir() {
        int c = JOptionPane.showConfirmDialog(frame,
                "Seguro que quieres salir?", "Salir", JOptionPane.YES_NO_OPTION);
        if (c == JOptionPane.YES_OPTION) System.exit(0);
    }
private JButton crearBoton(String texto) {
        JButton btn = new JButton(texto);
        btn.setFont(new Font("Arial", Font.BOLD, 14));
        btn.setBackground(new Color(0, 120, 200));
        btn.setForeground(Color.WHITE);
        btn.setFocusPainted(false);
        btn.setBorder(BorderFactory.createEmptyBorder(8, 20, 8, 20));
        btn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        return btn;
    }
}
